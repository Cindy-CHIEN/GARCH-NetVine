###============ de-GARCH ==================##
data2<-simdata

window_size <- 250
n_stocks <- 10

fit_results <- list()
degarched_returns <- list()
fitted_values <- list()
coeff_list <- list()

for (j in 1:n_stocks) {
  spec <- ugarchspec(variance.model = list(model = "sGARCH", garchOrder = c(1, 1)),
                     mean.model = list(armaOrder = c(1, 0)),
                     distribution.model = "norm")
  fit <- ugarchfit(spec, data = data2[(1:500), j], solver = "hybrid")
  fit_results[[j]] <- fit
  coeff_list[[j]] <- coef(fit)
  r_t <- fitted(fit)
  fitted_values[[j]] <- r_t
  degarched_return <- residuals(fit, standardize = TRUE)
  degarched_returns[[j]] <- degarched_return
}

# fitts <- do.call(cbind,fitted_values)
data_degarch <- do.call(cbind, degarched_returns)
colnames(data_degarch) <- as.character(1:10)

roll1 <- ugarchroll(
  spec = spec,
  data = data2,  # 假設 data2 是時間序列數據
  n.ahead = 1,  # 一步預測
  forecast.length = 250,  # 預測 250 天
  solver = 'hybrid',
  calculate.VaR = FALSE,  # 不生成 VaR 預測
  n.start = 250,  # 使用前 250 天數據進行初始模型配適
  refit.every = 1,  # 每隔 1 步重新配適
  refit.window = 'moving',  # 移動窗口
  window.size = 250,  # 窗口大小設為 250
  solver.control = list(tol = 1e-6, trace = 1),
  fit.control = list(scale = 1)
)

# 合并 fitted_values 和 roll1 一步预测值
fitts <- do.call(cbind, fitted_values)
predicted <- roll1@forecast$density$Mu  # 提取一步预测值

# 在切线投资组合计算中，前250天使用拟合值，后续使用一步预测值
# Rolling window portfolio optimization with de-GARCHed returns
mea2 <- list()
equalWeight2 <- list()
equalWeight_mean2 <- numeric(nrow(data_degarch) - 250)
tan_weight2 <- list()

for (i in 1:(nrow(data_degarch) - 250)) {
  # 根据i的值判断使用拟合值还是预测值
  if (i <= 250) {
    data_window <- fitts[i:(249 + i), ]  # 使用拟合值
  } else {
    data_window <- predicted[(i - 250):(249 + i - 250), ]  # 使用一步预测值
  }
  
  mean_ret2 <- colMeans(data_window)
  cov_mat2 <- cov(data_degarch[i:(249 + i), ])
  
  equalWeight.portfolio2 <- getPortfolio(er = mean_ret2, cov.mat = cov_mat2, weights = ew)
  equalWeight2[[i]] <- equalWeight.portfolio2
  equalWeight_mean2[i] <- equalWeight.portfolio2$er
  
  tan_weight_current <- tryCatch({
    tan.port2 <- tangency.portfolio(mean_ret2, cov_mat2, r.f, shorts = TRUE)
    tan.port2$weights
  }, error = function(e) {
    # If tangency portfolio fails, use global minimum variance portfolio
    gmin.port2 <- globalMin.portfolio(mean_ret2, cov_mat2)
    gmin.port2$weights
  })
  tan_weight2[[i]] <- tan_weight_current
}

weight_tan2 <- do.call(rbind, tan_weight2)


