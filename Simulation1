##================== set seed =======================##
set.seed(10000001)
n <- 500  
q <- 10
num_simulations <- 100  # Number of simulations

# -------------------------------------- #
#### ===== Initialize Storage ===== ####
all_V <- matrix(NA, nrow = n - 250 + 1, ncol = num_simulations)
all_V2 <- matrix(NA, nrow = n - 250 + 1, ncol = num_simulations)
#======== Generate ARMA(1,0)-GARCH(1,1) model =====#
for (sim in 1:num_simulations) {
r <- matrix(0, nrow = n, ncol = q) 
sigma2 <- matrix(0, nrow = n, ncol = q) 
a <- matrix(0, nrow = n, ncol = q)  

mu <- runif(q, 0.01, 0.1)  # mu
phi <- runif(q, 0.1, 0.8)  # ar1
omega <- runif(q, 0, 0.1)  # omega
gamma <- runif(q, 0.1, 0.15)  # alpha1
beta <- runif(q, 0.8, 0.9)  # beta1

# 確保 alpha1 + beta1 < 1
for (i in 1:q) {
  while ((gamma[i] + beta[i]) >= 1) {
    gamma[i] <- runif(1, 0.1, 0.15)
    beta[i] <- runif(1, 0.7, 0.85)
  }
}

epsilon<-matrix(rnorm(n * q, 0, 1), nrow = n, ncol = q)
##=========== 使用 ARMA-GARCH 模型模擬數據 =============##
for (i in 1:q) {
  sigma2[1, i] <- omega[i] / (1 - beta[i] - gamma[i]) 
  a[1, i] <- sqrt(sigma2[1, i]) * epsilon[1, i]     
  r[1, i] <- mu[i]  
}

# 模擬每個資產的 AR(1)-GARCH(1,1) 過程
for (i in 1:q) {
  for (t in 2:n) {
    sigma2[t, i] <- omega[i] + beta[i] * a[t-1, i]^2 + gamma[i] * sigma2[t-1, i]  # 波動率平方更新
    a[t, i] <- sqrt(sigma2[t, i]) * epsilon[t, i] 
    r[t, i] <- mu[i] + phi[i] * r[t-1, i] + a[t, i] 
    
  }
}
simdata<- data.frame(r)
names(simdata) <- paste0("Asset_", 1:q)

