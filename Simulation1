##========= no degarch ===================##
data1<-simdata

mea <- list()
equalWeight <- list()
equalWeight_mean <- numeric(nrow(data1) - 250)
tan_weight <- list()

# 定義等權重投資組合（20 隻股票，每隻權重 1/20）
ew <- rep(1, 10) / 10

# 風險無風險利率
r.f <- 0.0372 / 250

# 滾動窗口法進行投資組合優化
for (i in 1:(nrow(data1) - 250)) {
  # 選擇當前窗口的 250 個觀測值
  data_window <- data1[i:(249 + i), ]
  
  # 計算窗口內的平均收益
  mean_ret <- colMeans(data_window) 
  
  # 計算窗口內的協方差矩陣並進行對角線調整
  cov_mat <- cov(data_window) + 0.001 * diag(ncol(data_window))
  
  # 計算等權重投資組合
  equalWeight.portfolio <- getPortfolio(er = mean_ret, cov.mat = cov_mat, weights = ew)
  
  # 儲存等權重投資組合結果
  equalWeight[[i]] <- equalWeight.portfolio
  
  # 儲存等權重投資組合的平均收益
  equalWeight_mean[i] <- equalWeight.portfolio$er
  
  # 計算切線投資組合
  tan.port <- tangency.portfolio(mean_ret, cov_mat, r.f, shorts = TRUE)
  
  # 提取並儲存切線投資組合的權重
  tanwei <- tan.port$weights
  tan_weight[[i]] <- tanwei
}

# 將所有切線投資組合的權重合併為一個矩陣
weight_tan <- do.call(rbind, tan_weight)

