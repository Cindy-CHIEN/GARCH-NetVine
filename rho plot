plot_two_panel <- function(df, rho_star = 0.20, vlines = NULL) {
  
  oldpar <- par(no.readonly = TRUE)
  on.exit(par(oldpar))
  
  par(mfrow = c(1, 2), mar = c(5, 5, 4, 2))
  
  ylim_all <- range(c(df$rho_pearson, df$rho_kendall, rho_star, 0), na.rm = TRUE)
  ylim_all <- ylim_all + c(-0.03, 0.03)
  
  # ----- Pearson -----
  grp_p <- ifelse(df$rho_pearson > rho_star, "H", "L")
  
  plot(df$cycle, df$rho_pearson,
       type = "l",
       col = "royalblue4",
       lwd = 1,
       xlab = "Cycle",
       ylab = expression(rho(SR, C)),
       main = expression(rho(SR, C) ~ "\u2013 Pearson"),
       ylim = ylim_all)
  
  points(df$cycle[grp_p == "H"], df$rho_pearson[grp_p == "H"],
         pch = 16, col = "blue", cex = 0.8)
  points(df$cycle[grp_p == "L"], df$rho_pearson[grp_p == "L"],
         pch = 16, col = "orange", cex = 0.8)
  
  abline(h = 0, col = "royalblue4", lwd = 1)
  #abline(h = rho_star, col = "firebrick", lty = 2, lwd = 1)
  
  if (!is.null(vlines)) {
    abline(v = vlines, col = "grey60", lty = 2)
  }
  
  # ----- Kendall -----
  grp_k <- ifelse(df$rho_kendall > rho_star, "H", "L")
  
  plot(df$cycle, df$rho_kendall,
       type = "l",
       col = "goldenrod3",
       lwd = 1,
       xlab = "Cycle",
       ylab = expression(rho(SR, C)),
       main = expression(rho(SR, C) ~ "\u2013 Kendall"),
       ylim = ylim_all)
  
  points(df$cycle[grp_k == "H"], df$rho_kendall[grp_k == "H"],
         pch = 16, col = "blue", cex = 0.8)
  points(df$cycle[grp_k == "L"], df$rho_kendall[grp_k == "L"],
         pch = 16, col = "orange", cex = 0.8)
  
  abline(h = 0, col = "royalblue4", lwd = 1)
  #abline(h = rho_star, col = "firebrick", lty = 2, lwd = 1)
  
  if (!is.null(vlines)) {
    abline(v = vlines, col = "grey60", lty = 2)
  }
  
  # legend("topright",
  #        legend = c("High centrality (H)", "Low centrality (L)", "rho threshold"),
  #        col = c("blue", "orange", "firebrick"),
  #        pch = c(16, 16, NA),
  #        lty = c(NA, NA, 2),
  #        bty = "n",
  #        cex = 0.9)
}

plot_two_panel(rho_results, rho_star = rho_star, vlines = vlines_at)


plot_two_panel_year <- function(df, rho_star = 0.20, vlines = NULL) {
  
  oldpar <- par(no.readonly = TRUE)
  on.exit(par(oldpar))
  
  par(mfrow = c(1, 2), mar = c(5, 5, 4, 2))
  
  # 確保日期格式正確
  df$start <- as.Date(df$start)
  df$end   <- as.Date(df$end)
  
  # 用 end date 當作每個點的時間位置
  x_date <- df$end
  
  ylim_all <- range(c(df$rho_pearson, df$rho_kendall, rho_star, 0), na.rm = TRUE)
  ylim_all <- ylim_all + c(-0.03, 0.03)
  
  # 年份刻度
  x_min <- min(x_date, na.rm = TRUE)
  x_max <- max(x_date, na.rm = TRUE)
  
  year_ticks <- seq(
    from = as.Date(paste0(format(x_min, "%Y"), "-01-01")),
    to   = as.Date(paste0(format(x_max, "%Y"), "-01-01")),
    by   = "1 year"
  )
  
  # vlines 如果給的是 cycle，就轉成對應 end date
  if (!is.null(vlines)) {
    if (is.numeric(vlines)) {
      vline_dates <- x_date[vlines[vlines >= 1 & vlines <= nrow(df)]]
    } else {
      vline_dates <- as.Date(vlines)
    }
  } else {
    vline_dates <- NULL
  }
  
  # ---------- Pearson ----------
  grp_p <- ifelse(df$rho_pearson > rho_star, "H", "L")
  
  plot(x_date, df$rho_pearson,
       type = "l",
       col = "royalblue4",
       lwd = 1,
       xlab = "Year",
       ylab = expression(rho(SR, C)),
       main = expression(rho(SR, C) ~ "\u2013 Pearson"),
       ylim = ylim_all,
       xaxt = "n")
  
  axis(1, at = year_ticks, labels = format(year_ticks, "%Y"))
  
  points(x_date[grp_p == "H"], df$rho_pearson[grp_p == "H"],
         pch = 16, col = "blue", cex = 0.8)
  points(x_date[grp_p == "L"], df$rho_pearson[grp_p == "L"],
         pch = 16, col = "orange", cex = 0.8)
  
  abline(h = 0, col = "royalblue4", lwd = 1)
  
  if (!is.null(vline_dates)) {
    abline(v = vline_dates, col = "grey60", lty = 2)
  }
  
  # ---------- Kendall ----------
  grp_k <- ifelse(df$rho_kendall > rho_star, "H", "L")
  
  plot(x_date, df$rho_kendall,
       type = "l",
       col = "goldenrod3",
       lwd = 1,
       xlab = "Year",
       ylab = expression(rho(SR, C)),
       main = expression(rho(SR, C) ~ "\u2013 Kendall"),
       ylim = ylim_all,
       xaxt = "n")
  
  axis(1, at = year_ticks, labels = format(year_ticks, "%Y"))
  
  points(x_date[grp_k == "H"], df$rho_kendall[grp_k == "H"],
         pch = 16, col = "blue", cex = 0.8)
  points(x_date[grp_k == "L"], df$rho_kendall[grp_k == "L"],
         pch = 16, col = "orange", cex = 0.8)
  
  abline(h = 0, col = "royalblue4", lwd = 1)
  
  if (!is.null(vline_dates)) {
    abline(v = vline_dates, col = "grey60", lty = 2)
  }
}

