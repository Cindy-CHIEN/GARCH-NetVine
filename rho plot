sp_prices <- NULL
valid_symbols <- c()

for (sym in sp100_tickers) {
  obj <- tryCatch(get(sym), error = function(e) NULL)
  if (!is.null(obj)) {
    sp_prices <- cbind(sp_prices, Ad(obj))
    valid_symbols <- c(valid_symbols, sym)
  }
}

colnames(sp_prices) <- valid_symbols

# daily log returns
log_returns <- diff(log(sp_prices))
log_returns <- log_returns[complete.cases(log_returns), ]

cat("Data loaded.\n")
cat("Tickers used:", ncol(log_returns), "\n")
cat("Date range:", as.character(start(log_returns)), "to", as.character(end(log_returns)), "\n\n")

############################
# 4. Rolling calculation
############################
start_dates <- seq.Date(
  from = as.Date(start_date),
  to   = as.Date(end_date) %m-% months(window_months) + days(1),
  by   = paste(step_months, "months")
)

rho_results <- data.frame(
  cycle = integer(),
  start = as.Date(character()),
  end = as.Date(character()),
  n_stocks = integer(),
  rho_pearson = numeric(),
  rho_kendall = numeric(),
  stringsAsFactors = FALSE
)

for (i in seq_along(start_dates)) {
  s <- start_dates[i]
  e <- s %m+% months(window_months) - days(1)
  
  ret_window <- log_returns[paste0(s, "/", e)]
  
  out <- compute_cycle_rho_mst(ret_window, min_obs = min_obs)
  
  rho_results <- rbind(
    rho_results,
    data.frame(
      cycle = i,
      start = s,
      end = e,
      n_stocks = out$n_stocks,
      rho_pearson = out$rho_pearson,
      rho_kendall = out$rho_kendall
    )
  )
  
  cat(sprintf(
    "Cycle %d done. [%s to %s] Pearson = %.4f, Kendall = %.4f, n = %d\n",
    i, as.character(s), as.character(e),
    out$rho_pearson, out$rho_kendall, out$n_stocks
  ))
}

cat("\nFinal rho results:\n")
print(rho_results)

