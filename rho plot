# corr -> distance
if (!exists("corr2dist", mode = "function")) {
  corr2dist <- function(C, method = c("pearson", "kendall")) {
    method <- match.arg(method)
    D <- if (method == "pearson") 1 - C^2 else (1 - C) / 2
    diag(D) <- 0
    as.dist(D)
  }
}

# de-GARCH standardized residuals
get_std_resid <- function(x) {
  x <- as.numeric(x)
  
  if (sum(is.finite(x)) < 100) {
    return(rep(NA_real_, length(x)))
  }
  
  spec <- ugarchspec(
    variance.model = list(model = "sGARCH", garchOrder = c(1, 1)),
    mean.model = list(armaOrder = c(0, 0), include.mean = TRUE),
    distribution.model = "norm"
  )
  
  fit <- tryCatch(
    ugarchfit(spec = spec, data = x, solver = "hybrid", silent = TRUE),
    error = function(e) NULL
  )
  
  if (is.null(fit)) {
    return(rep(NA_real_, length(x)))
  }
  
  res <- tryCatch(
    as.numeric(residuals(fit, standardize = TRUE)),
    error = function(e) rep(NA_real_, length(x))
  )
  
  if (length(res) != length(x)) {
    return(rep(NA_real_, length(x)))
  }
  
  res
}

# 單一 cycle 計算
compute_cycle_rho_mst <- function(ret_window_xts, min_obs = 150) {
  
  R <- coredata(ret_window_xts)
  colnames(R) <- colnames(ret_window_xts)
  
  # 先留資料夠多的股票
  keep1 <- colSums(is.finite(R)) >= min_obs
  R <- R[, keep1, drop = FALSE]
  
  if (ncol(R) < 5) {
    return(list(
      n_stocks = ncol(R),
      rho_pearson = NA_real_,
      rho_kendall = NA_real_,
      sr = NULL,
      ec_pearson = NULL,
      ec_kendall = NULL
    ))
  }
  
  # de-GARCH residuals
  resid_mat <- matrix(NA_real_, nrow = nrow(R), ncol = ncol(R))
  colnames(resid_mat) <- colnames(R)
  
  for (j in seq_len(ncol(R))) {
    resid_mat[, j] <- get_std_resid(R[, j])
  }
  
  # 再篩一次
  keep2 <- colSums(is.finite(resid_mat)) >= min_obs
  resid_mat <- resid_mat[, keep2, drop = FALSE]
  R <- R[, keep2, drop = FALSE]
  
  if (ncol(R) < 5) {
    return(list(
      n_stocks = ncol(R),
      rho_pearson = NA_real_,
      rho_kendall = NA_real_,
      sr = NULL,
      ec_pearson = NULL,
      ec_kendall = NULL
    ))
  }
  
  # 只保留完整列
  cc <- complete.cases(resid_mat)
  resid_mat <- resid_mat[cc, , drop = FALSE]
  R <- R[cc, , drop = FALSE]
  
  if (nrow(resid_mat) < min_obs || ncol(resid_mat) < 5) {
    return(list(
      n_stocks = ncol(R),
      rho_pearson = NA_real_,
      rho_kendall = NA_real_,
      sr = NULL,
      ec_pearson = NULL,
      ec_kendall = NULL
    ))
  }
  
  # stock-level Sharpe ratio
  sr <- apply(R, 2, function(x) {
    s <- sd(x, na.rm = TRUE)
    m <- mean(x, na.rm = TRUE)
    if (!is.finite(s) || s == 0) return(NA_real_)
    m / s
  })
  
  # ---------- Pearson network ----------
  C_p <- cor(resid_mat, use = "pairwise.complete.obs", method = "pearson")
  C_p[!is.finite(C_p)] <- 0
  diag(C_p) <- 1
  
  D_p <- corr2dist(C_p, method = "pearson")
  mst_p <- as.matrix(ape::mst(D_p))
  
  g_p <- igraph::graph_from_adjacency_matrix(
    mst_p,
    mode = "undirected",
    weighted = TRUE,
    diag = FALSE
  )
  
  ec_p <- tryCatch(
    igraph::eigen_centrality(g_p, directed = FALSE, weights = igraph::E(g_p)$weight)$vector,
    error = function(e) NULL
  )
  
  # ---------- Kendall network ----------
  C_k <- cor(resid_mat, use = "pairwise.complete.obs", method = "kendall")
  C_k[!is.finite(C_k)] <- 0
  diag(C_k) <- 1
  
  D_k <- corr2dist(C_k, method = "kendall")
  mst_k <- as.matrix(ape::mst(D_k))
  
  g_k <- igraph::graph_from_adjacency_matrix(
    mst_k,
    mode = "undirected",
    weighted = TRUE,
    diag = FALSE
  )
  
  ec_k <- tryCatch(
    igraph::eigen_centrality(g_k, directed = FALSE, weights = igraph::E(g_k)$weight)$vector,
    error = function(e) NULL
  )
  
  # 對齊名稱
  rho_p <- NA_real_
  rho_k <- NA_real_
  
  if (!is.null(ec_p)) {
    common_p <- intersect(names(sr), names(ec_p))
    sr_p <- sr[common_p]
    ec_p2 <- ec_p[common_p]
    ok_p <- complete.cases(sr_p, ec_p2)
    sr_p <- sr_p[ok_p]
    ec_p2 <- ec_p2[ok_p]
    
    if (length(sr_p) >= 5) {
      rho_p <- suppressWarnings(cor(sr_p, ec_p2, method = "pearson"))
    }
  }
  
  if (!is.null(ec_k)) {
    common_k <- intersect(names(sr), names(ec_k))
    sr_k <- sr[common_k]
    ec_k2 <- ec_k[common_k]
    ok_k <- complete.cases(sr_k, ec_k2)
    sr_k <- sr_k[ok_k]
    ec_k2 <- ec_k2[ok_k]
    
    if (length(sr_k) >= 5) {
      rho_k <- suppressWarnings(cor(sr_k, ec_k2, method = "kendall"))
    }
  }
  
  list(
    n_stocks = length(sr),
    rho_pearson = rho_p,
    rho_kendall = rho_k,
    sr = sr,
    ec_pearson = ec_p,
    ec_kendall = ec_k
  )
}

