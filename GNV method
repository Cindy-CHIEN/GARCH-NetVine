rho_grid <- seq(0, 0.2, by = 0.1)

run_one_th <- function(th, corr_method = "pearson", seed = 123) {
  set.seed(seed)
  
  out <- simulate_portfolio_ec(
    corr_method = corr_method,
    selection   = "auto",
    rho_th      = th,
    fee         = fee_default,
    est_length  = 250,
    hold_length = 62,
    shift       = 63,
    top_n       = 20,
    familyset   = 1,
    n_sim_corr  = 5000
  )
  
  if (length(out$values) < 2) return(NA_real_)
  AUC(out$dates, out$values)
}

