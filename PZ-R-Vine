#### ============ 自訂函數：切點投資組合（禁止空頭） ================= ####
tangency_portfolio_no_short <- function(mean_ret, cov_mat, r_f) {
  excess_returns <- mean_ret - r_f
  cov_inv <- solve(cov_mat)
  numerator <- cov_inv %*% excess_returns
  denominator <- sum(cov_inv %*% excess_returns)
  weights <- numerator / denominator
  weights[weights < 0] <- 0
  weights <- weights / sum(weights)
  return(as.numeric(weights))
}
