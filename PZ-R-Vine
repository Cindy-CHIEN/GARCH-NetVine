##------------------------------------------------------------
## 2. 取出 zoo 物件中的 x 與 y，直接套梯形積分
##------------------------------------------------------------
AUC <- function(z) {
  t <- as.numeric(index(z))           # 轉成數值日期
  y <- coredata(z)
  trapz(t, y)                         # pracma::trapz
}

auc_P_H <- AUC(z_vp_h)
auc_P_L <- AUC(z_vp_l)
auc_K_H <- AUC(z_vk_h)
auc_K_L <- AUC(z_vk_l)
auc_OEX <- AUC(OEX.rtn)               # 基準 S&P 100

